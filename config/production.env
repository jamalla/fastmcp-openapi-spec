# Salla API Configuration - Production Environment
SALLA_BASE_URL=https://api.salla.dev/v2
SALLA_API_TOKEN=your-production-token-here

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Logging
LOG_LEVEL=WARNING
LOG_FORMAT=json

# API Client
API_TIMEOUT=30
API_RETRIES=3

# Features
ENABLE_REQUEST_VALIDATION=true
ENABLE_RESPONSE_VALIDATION=true
ENABLE_METRICS=true
