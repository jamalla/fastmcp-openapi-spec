# Salla API Configuration - Development Environment
SALLA_BASE_URL=https://api.salla.dev/v2
SALLA_API_TOKEN=your-dev-token-here

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8000

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# API Client
API_TIMEOUT=30
API_RETRIES=0

# Features
ENABLE_REQUEST_VALIDATION=true
ENABLE_RESPONSE_VALIDATION=true
ENABLE_METRICS=false

