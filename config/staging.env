# Salla API Configuration - Staging Environment
SALLA_BASE_URL=https://staging-api.salla.dev/v2
SALLA_API_TOKEN=your-staging-token-here

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# API Client
API_TIMEOUT=30
API_RETRIES=2

# Features
ENABLE_REQUEST_VALIDATION=true
ENABLE_RESPONSE_VALIDATION=true
ENABLE_METRICS=true
